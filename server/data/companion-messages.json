      ],
      "messages": [
        {
          "id": "dog_msg_001",
          "text": "累了吗？休息一下吧 🌿 你不需要一直保持'生产力'状态。",
          "ppFramework": "selfCompassion",
          "growthOriented": true,
          "selfCompassion": true,
          "evidenceBased": "Maslach (2016) - 职业倦怠与休息的重要性"
        },
        {
          "id": "dog_msg_002",
          "text": "不管怎样，我都陪着你。不是'虽然你...但是我爱你'，而是'因为是你，所以爱你'。",
          "ppFramework": "unconditionalPositiveRegard",
          "growthOriented": false,
          "selfCompassion": true,
          "evidenceBased": "Rogers (1951) - 无条件积极关注"
        },
        {
          "id": "dog_msg_003",
          "text": "你做得很好，真的。不是和别人比，是和昨天的自己比。",
          "ppFramework": "accomplishment",
          "growthOriented": true,
          "selfCompassion": false,
          "evidenceBased": "Bandura (1997) - 自我效能感理论"
        },
        {
          "id": "dog_msg_004",
          "text": "有什么心事想说吗？我听。不用逻辑清晰，不用'有意义'，我只是想听你说。",
          "ppFramework": "activeListening",
          "growthOriented": false,
          "selfCompassion": false,
          "evidenceBased": "的机制 (Rogers) - 主动倾听"
        },
        {
          "id": "dog_msg_005",
          "text": "不需要理由，你本来就很重要。存在本身就是价值，不需要成就来证明。",
          "ppFramework": "meaning",
          "growthOriented": false,
          "selfCompassion": true,
          "evidenceBased": "Frankl (1946) - 意义疗法"
        },
        {
          "id": "dog_msg_006",
          "text": "我在这里，不走的。就算你看不见我，我也在。",
          "ppFramework": "secureBase",
          "growthOriented": false,
          "selfCompassion": false,
          "evidenceBased": "Bowlby (1969) - 依恋理论的安全基地"
        },
        {
          "id": "dog_msg_007",
          "text": "今天辛苦啦，摸摸头 🐾 你今天应对了那么多事，很了不起。",
          "ppFramework": "emotionalValidation",
          "growthOriented": false,
          "selfCompassion": true,
          "evidenceBased": "Neff (2003) - 自我同情"
        },
