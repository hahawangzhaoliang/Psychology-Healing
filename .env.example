# 心晴空间 - 环境配置

# 服务器配置
NODE_ENV=development
PORT=3000

# Upstash Search 数据库配置
UPSTASH_SEARCH_REST_URL=https://your-instance.upstash.io
UPSTASH_SEARCH_REST_TOKEN=your-token
UPSTASH_SEARCH_REST_READONLY_TOKEN=your-readonly-token

# 知识库更新密钥（手动触发 cron-update 接口时使用）
KNOWLEDGE_UPDATE_SECRET=your-random-secret-key

# 管理后台登录令牌（admin.html 登录用，请设置为随机强令牌）
ADMIN_TOKEN=your-admin-token-here

# CORS配置
CORS_ORIGIN=*

# 日志级别
LOG_LEVEL=debug
